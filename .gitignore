.DS_Store
.private/

# Python caches and build artefacts
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
build/
dist/
*.gguf
*.ggml
llama-cli
llama-server

# Local environments and tooling
.venv/
.python-version
models/local/*
!models/local/README.md
!models/local/model_metadata.json
.cache/llama.cpp/
.cache/llama-cpp-python/
models/**/*.bin
models/**/*.safetensors
models/**/*.pt
models/**/*.onnx

# Secrets and local configuration
.env
.env.*
!.env.example
*.pem
*.key

# Generated run artefacts
outputs/*
!outputs/.gitkeep
!outputs/runs/
outputs/runs/*
!outputs/runs/.gitkeep

# Editor state
.idea/
.vscode/
*.swp
